# Required
DISCORD_BOT_TOKEN=your-bot-token-here

# Optional - Default working directory for Claude sessions
# Default: ~/.disclaw (override with absolute path)
# CLAUDE_WORKING_DIR=/path/to/your/project

# Optional - Log directory
# Default: $XDG_STATE_HOME/disclaw/logs (~/.local/state/disclaw/logs)
# LOG_DIR=/path/to/logs

# Optional - Security allowlist for working directories (comma-separated)
# DISCLAW_ALLOWED_DIRS=/path/to/project1,/path/to/project2

# Optional - Default permission mode: default, dontAsk, acceptEdits, bypassPermissions, plan
# DISCLAW_PERMISSION_MODE=default

# Optional - Timezone for datetime injection
TZ=America/New_York
